#!/usr/bin/env bash
set -e

name="$(basename $(cd "$(dirname $(dirname "$0"))"; pwd -P))"
underscore_name=${name//-/_}
spaceless_name=${name//-/}

# ---- choose sed ----
if command -v gsed >/dev/null 2>&1; then
    SED="gsed"
    sedflags=(-i)
else
    SED="sed"
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sedflags=(-i "")
    else
        sedflags=(-i)
    fi
fi

# ---- safe file iteration ----
find . \
    -path ./.git -prune -o \
    -path ./__pycache__ -prune -o \
    -type f -print0 |
while IFS= read -r -d '' file; do

    file_name=$(basename "$file")

    case $file_name in
        rename)
            echo "Skipping $file"
            continue;;
    esac

    # skip binary files (critical)
    if ! grep -Iq . "$file"; then
        continue
    fi

    set +e
    LC_ALL=C $SED "${sedflags[@]}" -e "s/stactools-ephemeral/stactools-${name}/g" "$file"
    LC_ALL=C $SED "${sedflags[@]}" -e "s/stactools\.ephemeral/stactools.${underscore_name}/g" "$file"
    LC_ALL=C $SED "${sedflags[@]}" -e "s/stactools_ephemeral/stactools_${underscore_name}/g" "$file"
    LC_ALL=C $SED "${sedflags[@]}" -e "s;stactools/ephemeral;stactools/${underscore_name};g" "$file"
    LC_ALL=C $SED "${sedflags[@]}" -e "s/ephemeralcmd/${spaceless_name}/g" "$file"
    LC_ALL=C $SED "${sedflags[@]}" -e "s/ephemeral/${name}/g" "$file"
    set -e

done

if [ -d src/stactools/ephemeral ]; then
    git mv src/stactools/ephemeral src/stactools/$underscore_name
fi

echo "Rename complete"